$radius-xs: 12px;
$radius-sm: 16px;
$radius-md: 22px;
$radius-lg: 30px;

$shadow-light: 0 1px 2px alpha(#000000, 0.06), 0 24px 48px alpha(#000000, 0.05);
$shadow-dark: 0 1px 2px alpha(#000000, 0.38), 0 24px 48px alpha(#000000, 0.28);

$sidebar-width: 17rem;
$rail-width: 16rem;
$content-max: 92rem;
$topbar-height: 4.75rem;

$transition-fast: 160ms ease;
$transition-slow: 240ms ease;
